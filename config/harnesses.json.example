{
  "schema_version": 1,
  "harnesses": {
    "generic": {
      "type": "shell",
      "start_command": "/bin/bash",
      "description": "plain interactive bash shell — the default harness"
    },
    "bash-login": {
      "type": "shell",
      "start_command": "/bin/bash -l",
      "working_dir": "/home/whizzard",
      "env": {
        "EXAMPLE": "1"
      },
      "description": "login shell variant with example env injection"
    },
    "hermes": {
      "type": "agent",
      "start_command": "hermes",
      "wrap_up_command": "/quit",
      "wrap_up_grace_seconds": 30,
      "hermes_home": "~/.hermes-whizzard-cell",
      "platforms": ["discord"],
      "model_credential": {
        "provider": "anthropic",
        "secret": "ANTHROPIC_API_KEY",
        "base_url_env": "ANTHROPIC_BASE_URL"
      },
      "secrets": [
        "DISCORD_BOT_TOKEN"
      ],
      "description": "Whizzard-wrapped Hermes. `model_credential` names the model key/login, resolved host-side — in a mediated/hybrid profile the cell sees only a placeholder + broker URL, never the real value. `secrets` lists OTHER env-var names whose real values are fetched (OneCLI vault -> host env) and injected into the cell; use it for tokens that mediation/OneCLI don't already cover. The model secret must NOT also appear in `secrets`."
    }
  }
}
