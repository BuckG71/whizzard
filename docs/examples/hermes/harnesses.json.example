{
  "schema_version": 1,
  "harnesses": {
    "generic": {
      "type": "shell",
      "start_command": "/bin/bash",
      "description": "plain interactive bash shell — the default harness"
    },

    "hermes-sandbox": {
      "type": "agent",
      "start_command": "hermes gateway run",
      "wrap_up_command": "/quit",
      "wrap_up_grace_seconds": 30,
      "hermes_home": "~/.hermes-whizzard-sandbox",
      "platforms": ["discord"],
      "secrets": ["ANTHROPIC_API_KEY"],
      "description": "Whizzard-wrapped Hermes (gateway mode, Discord active). Production-shape; needs DISCORD_BOT_TOKEN + ANTHROPIC_API_KEY available via OneCLI or host env."
    },

    "hermes-sandbox-smoke": {
      "type": "agent",
      "start_command": "hermes chat",
      "wrap_up_command": "/quit",
      "wrap_up_grace_seconds": 30,
      "hermes_home": "~/.hermes-whizzard-sandbox",
      "description": "Smoke variant: interactive chat mode, no platforms, no LLM-provider secrets injection. Use this for first-launch validation with a local Ollama provider configured in the sandbox's config.yaml. No external credentials required."
    }
  }
}
